@page "/editor"
@rendermode InteractiveServer

@using System.Globalization
@using RTE.Components.RichTextEditor
@using RTE.Components.RichTextEditor.Enum

@inject IWebHostEnvironment Environment

<PageTitle>Editor</PageTitle>

<div class="row g-3">
    <div class="col-12 col-md-3">
        <label for="editor-language" class="form-label">Editor language</label>
        <select id="editor-language"
                class="form-select"
                value="@_selectedLanguage"
                @onchange="OnLanguageChanged">
            @foreach (var language in _availableLanguages)
            {
                <option value="@language.Code"
                        @(language.Code == _selectedLanguage ? "selected" : null)>@language.DisplayName</option>
            }
        </select>
    </div>

    <div class="col offset-md-9"></div>

    <div class="col-6 min-w-0">
        <div dir="@GetDirection(_selectedLanguage)">
            @if (_editorOptions is not null)
            {
                <RichTextEditor @key="_selectedLanguage"
                    @bind-Value="_content"
                                Options="@_editorOptions"/>
            }
        </div>
    </div>

    <div class="col-6">
        <pre>@_content</pre>
    </div>

    <div class="col-12">
        @((MarkupString)_content)
    </div>
</div>

@code {
    private string _content = "";
    private string _selectedLanguage = "en";

    private sealed record EditorLanguage(string Code, string DisplayName);

    private IReadOnlyList<EditorLanguage> _availableLanguages = [];
    private RichTextEditorOptions? _editorOptions;

    protected override void OnAfterRender(bool firstRender)
    {
        Console.WriteLine("Rendered...");
        Console.WriteLine(_editorOptions is not null);
        if (!firstRender && _editorOptions is not null) return;
        _availableLanguages = GetAvailableLanguages();
        _selectedLanguage = _availableLanguages.Any(lang => lang.Code == "nl") ? "nl" : "en";

        Console.WriteLine("Calling CreateEditorOptions");
        _editorOptions = CreateEditorOptions(_selectedLanguage);
        StateHasChanged();
    }


    private void OnLanguageChanged(ChangeEventArgs args)
    {
        var language = args.Value?.ToString();

        if (string.IsNullOrWhiteSpace(language) || language == _selectedLanguage) return;

        _selectedLanguage = language;
        _editorOptions = CreateEditorOptions(_selectedLanguage);
    }

    private IReadOnlyList<EditorLanguage> GetAvailableLanguages()
    {
        var languages = new List<EditorLanguage>
        {
            new("en", "English")
        };

        var languageDirectory = Path.Combine(Environment.WebRootPath, "lib", "HugeRTE", "langs");

        if (!Directory.Exists(languageDirectory)) return languages;

        foreach (var file in Directory.EnumerateFiles(languageDirectory, "*.js"))
        {
            var code = Path.GetFileNameWithoutExtension(file);
            if (string.IsNullOrWhiteSpace(code) || code.Equals("en", StringComparison.OrdinalIgnoreCase))
            {
                continue;
            }

            languages.Add(new EditorLanguage(code, GetLanguageDisplayName(code)));
        }

        return languages.OrderBy(language => language.DisplayName).ToArray();
    }

    private static string GetLanguageDisplayName(string code)
    {
        try
        {
            var culture = CultureInfo.GetCultureInfo(code.Replace("_", "-"));
            return culture.NativeName;
        }
        catch (CultureNotFoundException)
        {
            return code;
        }
    }

    private static RichTextEditorOptions CreateEditorOptions(string language)
    {
        Console.WriteLine("Config created");
        var toolbar = new List<HugeRteToolbarGroup>
        {
            new() { Items = [HugeRteToolbarItem.Undo, HugeRteToolbarItem.Redo] },
            // new() { Items = [HugeRteToolbarItem.Blocks] },
            new() { Items = [HugeRteToolbarItem.Bold, HugeRteToolbarItem.Italic, HugeRteToolbarItem.Underline] },
            new() { Items = [HugeRteToolbarItem.AlignLeft, HugeRteToolbarItem.AlignCenter, HugeRteToolbarItem.AlignRight] },
            new() { Items = [HugeRteToolbarItem.BulletList, HugeRteToolbarItem.NumberedList] },
            new() { Items = [HugeRteToolbarItem.Outdent, HugeRteToolbarItem.Indent] },
            // new() { Items = [HugeRteToolbarItem.Link, HugeRteToolbarItem.Table] },
        };

        if (IsRightToLeftLanguage(language))
        {
            toolbar.Add(new HugeRteToolbarGroup
            {
                Items = [HugeRteToolbarItem.LeftToRight, HugeRteToolbarItem.RightToLeft]
            });
        }

        return new RichTextEditorOptions
        {
            Language = language,
            LanguageUrl = language.Equals("en", StringComparison.OrdinalIgnoreCase)
                ? null
                : $"/lib/HugeRTE/langs/{language}.js",
            BlockFormats = CreateBlockFormats(language),
            Statusbar = false,
            ExtraPlugins = HugeRtePlugins.AdvancedList
                           | HugeRtePlugins.WordCount
                           | HugeRtePlugins.AutoLink,
            Directionality = IsRightToLeftLanguage(language) ? "rtl" : "ltr",
            Toolbar = toolbar,
            SelectionQuickbar = true,
            InsertQuickbar = false,
            ImageQuickbar = false
        };
    }

