    private static string NormalizeLanguageCode(string language)
    {
        return language.Trim().Replace("-", "_").ToLowerInvariant();
    }

    private static bool IsRightToLeftLanguage(string language)
    {
        var normalized = NormalizeLanguageCode(language);

        return normalized is "ar" or "he_il";
    }

    private static string GetDirection(string language)
    {
        return IsRightToLeftLanguage(language) ? "rtl" : "ltr";
    }

